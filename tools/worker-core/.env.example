# Copia este archivo a .env y rellena los valores
# Uso con Ollama (compatible con Anthropic Messages API)

# Endpoint del proveedor LLM
# Ollama local:  http://localhost:11434
# Anthropic:     (dejar vacio, usa el endpoint oficial por defecto)
ANTHROPIC_BASE_URL=http://localhost:11434

# API key
# Ollama Cloud:  tu clave de https://ollama.com/settings/keys
# Anthropic:     sk-ant-...
# Ollama local:  ollama
ANTHROPIC_API_KEY=ollama

# Modelo para todos los agentes (orchestrator, browser, windows)
# Ejemplos: minimax-m2.7:cloud | llama3.1 | claude-opus-4-6
MODEL_NAME=minimax-m2.7:cloud

# Sobreescribir modelo por agente (opcional; si no se define usa MODEL_NAME)
# ORCHESTRATOR_MODEL=minimax-m2.7:cloud
# BROWSER_MODEL=minimax-m2.7:cloud
# WINDOWS_MODEL=minimax-m2.7:cloud

# Browser visible / Edge
# Por defecto browser-use abrira Microsoft Edge visible
BROWSER_HEADLESS=false
BROWSER_CHANNEL=msedge
# auto: activa vision solo para familias multimodales conocidas.
# true: fuerza screenshots al modelo.
# false: desactiva vision aunque el modelo la soporte.
BROWSER_USE_VISION=auto

# Para usar TU Edge ya abierto con la sesion iniciada:
# 1) cierra todas las ventanas de Edge
# 2) define:
# BROWSER_CDP_URL=http://127.0.0.1:9242
# 3) el adaptador intentara abrir Edge con este comando de PowerShell si CDP no esta disponible:
#    & "C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe" --remote-debugging-port=9242 --profile-directory=Default "https://www.freepik.com/pikaso/ai-image-generator"
# 4) si quieres cambiar la URL de arranque:
# BROWSER_CDP_BOOTSTRAP_URL=https://www.freepik.com/pikaso/ai-image-generator

# Opcional si quieres lanzar Edge visible con un perfil concreto
# BROWSER_EXECUTABLE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
# BROWSER_USER_DATA_DIR=C:\Users\TU_USUARIO\AppData\Local\Microsoft\Edge\User Data
# BROWSER_PROFILE_DIRECTORY=Default

# Limites de los agentes
MAX_RETRIES=1
MAX_STEPS_WINDOWS=25
MAX_STEPS_BROWSER=100

# Adaptadores habilitados (separados por coma)
# Opciones: files, data, browser, windows
# Empieza solo con files,data para la smoke test
# Los wrappers del repo (`run_browser.py`, `run_windows.py`, `run_worker.py`)
# pueden ampliar este allowlist en runtime sin modificar tu .env.
ACTION_ALLOWLIST=files,data

# Nivel de log (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Rutas opcionales (por defecto relativas a worker-core/)
# PLAYBOOKS_DIR=D:/IA/CODE/pc-worker/worker-core/playbooks
# LOGS_DIR=D:/IA/CODE/pc-worker/worker-core/logs
# TASKS_DIR=D:/IA/CODE/pc-worker/worker-core/tasks
# MEMORY_FILE=D:/IA/CODE/pc-worker/worker-core/memory.json
