# Primary single-agent defaults (highest priority)
# Copy this file to .env or export variables in your shell.

PRIMARY_AGENT=claude_code
PRIMARY_CLI=claude

# Experimental feature flags (disabled by default)
ENABLE_GROQ_EXPERIMENTAL=0
ENABLE_LOCAL_MULTIMODEL_EXPERIMENTAL=0

# Optional providers
# Never commit real API keys.
GROQ_API_KEY=YOUR_KEY_HERE
