      "rule_id": "RULE-001",
      "title": "Bypass Edge Lock",
      "status": "active",
      "mode": "enforced",
      "priority": 10,
      "scope": {
        "agent_ids": ["gemini_cli"],
        "workflow_ids": ["*"],
        "tool_ids": ["chatgpt"],
        "step_ids": ["cdp_connect"],
        "environments": ["win32"]
      },
      "pattern": {
        "event_type": "tool_failed",
        "error_types": ["Target closed", "lock"],
        "within_ms": 5000,
        "match": {
          "any": [
            { "path": "error_msg", "op": "contains", "value": "Target closed" },
            { "path": "error_msg", "op": "contains", "value": "lock" }
          ]
        }
      },
      "action": {
        "handler_id": "kill_and_retry_edge",
        "params": { "kill_first": true, "max_retries": 2 }
      },
